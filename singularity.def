Bootstrap: docker
From: python:3.10.4

%files
    smiles_transformer/ /smiles_transformer/
    requirements.txt /requirements.txt
    setup.py /setup.py
    /cluster/home/gsulpizio/github_token.txt /root/github_token.txt


%environment
    export WANDB_API_KEY=""
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export WANDB_CACHE_DIR=""
    export WANDB_DATA_DIR=""

%post

    GITHUB_TOKEN=$(cat /root/github_token.txt)
    git config --global url."https://${GITHUB_TOKEN}:x-oauth-basic@github.com/gSulpizio/".insteadOf "https://github.com/gSulpizio/"
    # --- 1. System Updates (Note: These fail on the cluster, see below) ---
    apt-get update && apt-get install -y python3-pip

    # --- 2. Python Setup ---
    pip install --upgrade pip

    # Pre-install build dependencies globally to handle CGRtools
    # We include numpy here as it is often a build dependency for scientific tools
    pip install "Cython<3" "numpy<2" wheel setuptools

    # --- 3. Install Requirements with NO BUILD ISOLATION ---
    # This forces pip to use the Cython<3 we just installed
    pip install --no-build-isolation --no-cache-dir -r /requirements.txt

    pip install .

    # --- 4. Create Directories ---
    mkdir -p /data/
    mkdir -p /configurations/
    mkdir -p /outputs/

%runscript
    if [ -z "$*" ]; then
        echo "No arguments provided. Please specify a Python module or script to run."
        exit 1
    else
        exec python -m $*
    fi